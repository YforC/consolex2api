OPENAI_API_KEY=replace-with-your-gateway-key
ADMIN_KEY=replace-with-your-admin-key

# Upstream auth: prefer SQLite account storage managed by /admin.
# UPSTREAM_SSO remains as a single-account fallback.
ACCOUNTS_DB=/app/data/accounts.sqlite3
UPSTREAM_SSO=
UPSTREAM_COOKIE=
UPSTREAM_CF_COOKIES=
UPSTREAM_CF_CLEARANCE=
UPSTREAM_CF_USER_AGENT=

UPSTREAM_URL=https://console.x.ai/v1/responses
UPSTREAM_X_CLUSTER=https://us-east-1.api.x.ai
UPSTREAM_ORIGIN=https://console.x.ai
UPSTREAM_REFERER=
UPSTREAM_USER_AGENT=Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/148.0.0.0 Safari/537.36
UPSTREAM_PROXY=
UPSTREAM_IMPERSONATE=chrome136
UPSTREAM_SKIP_SSL_VERIFY=false

GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8787
REQUEST_TIMEOUT_S=120
GATEWAY_TOOLS_ENABLED=true
DEFAULT_REASONING_EFFORT=

# Optional model list override; fallback is parsed from HAR file.
GATEWAY_MODELS=
HAR_FILE_PATH=

